<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Add visible search bar to home menu -->
    <t t-name="pan_style_pro_enterprise.HomeMenu" t-inherit="web_enterprise.HomeMenu" t-inherit-mode="extension">
        <xpath expr="//input[hasclass('o_search_hidden')]" position="after">
            <div class="pan-home-search mx-auto mt-4 mb-2">
                <div class="pan-home-search-box d-flex align-items-center" t-on-click="() => this._onSearchBarClick()">
                    <i class="fa fa-search me-3 opacity-50"/>
                    <span class="opacity-50">Search apps, menus, settings…</span>
                    <span class="pan-home-search-shortcut ms-auto">
                        <kbd>⌘</kbd><kbd>K</kbd>
                    </span>
                </div>
            </div>
        </xpath>
    </t>

</templates>
