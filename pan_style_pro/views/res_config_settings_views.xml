<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pan_style_pro</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Style Pro" string="Style Pro" name="pan_style_pro">
                    <h2>Colors</h2>
                    <div class="row mt-4 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <div class="pan-color-list">
                                    <!-- Header row -->
                                    <div class="pan-color-row pan-color-row--header">
                                        <span class="pan-color-label"/>
                                        <span class="pan-color-col-header">Light</span>
                                        <span class="pan-color-col-header">Dark</span>
                                    </div>
                                    <div class="pan-color-row">
                                        <label for="x_pan_accent_color" string="Accent" class="pan-color-label"/>
                                        <field name="x_pan_accent_color" widget="color"/>
                                        <field name="x_pan_dark_accent_color" widget="color"/>
                                    </div>
                                    <div class="pan-color-row">
                                        <label for="x_pan_accent_hover_color" string="Accent Hover" class="pan-color-label"/>
                                        <field name="x_pan_accent_hover_color" widget="color"/>
                                        <field name="x_pan_dark_accent_hover_color" widget="color"/>
                                    </div>
                                    <div class="pan-color-row">
                                        <label for="x_pan_bg_color" string="Background" class="pan-color-label"/>
                                        <field name="x_pan_bg_color" widget="color"/>
                                        <field name="x_pan_dark_bg_color" widget="color"/>
                                    </div>
                                    <div class="pan-color-row">
                                        <label for="x_pan_bg_secondary_color" string="Surface" class="pan-color-label"/>
                                        <field name="x_pan_bg_secondary_color" widget="color"/>
                                        <field name="x_pan_dark_bg_secondary_color" widget="color"/>
                                    </div>
                                    <div class="pan-color-row">
                                        <label for="x_pan_text_color" string="Text" class="pan-color-label"/>
                                        <field name="x_pan_text_color" widget="color"/>
                                        <field name="x_pan_dark_text_color" widget="color"/>
                                    </div>
                                    <div class="pan-color-row">
                                        <label for="x_pan_navbar_bg_color" string="Navbar" class="pan-color-label"/>
                                        <field name="x_pan_navbar_bg_color" widget="color"/>
                                        <field name="x_pan_dark_navbar_bg_color" widget="color"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <h2>Fine-tuning</h2>
                    <div class="row mt-4 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <div class="pan-fine-tune-grid">
                                    <!-- Header row -->
                                    <div class="pan-fine-tune-item pan-fine-tune-item--header">
                                        <span class="pan-fine-tune-label"/>
                                        <span class="pan-fine-tune-col-header">Light</span>
                                        <span class="pan-fine-tune-col-header">Dark</span>
                                    </div>
                                    <div class="pan-fine-tune-item">
                                        <label for="x_pan_text_secondary_color" string="Muted Text" class="pan-fine-tune-label"/>
                                        <field name="x_pan_text_secondary_color" placeholder="rgba(0, 29, 33, 0.55)"/>
                                        <field name="x_pan_dark_text_secondary_color" placeholder="rgba(255, 255, 255, 0.42)"/>
                                    </div>
                                    <div class="pan-fine-tune-item">
                                        <label for="x_pan_border_color" string="Border" class="pan-fine-tune-label"/>
                                        <field name="x_pan_border_color" placeholder="rgba(0, 0, 0, 0.08)"/>
                                        <field name="x_pan_dark_border_color" placeholder="rgba(255, 255, 255, 0.09)"/>
                                    </div>
                                    <div class="pan-fine-tune-item">
                                        <label for="x_pan_border_strong_color" string="Strong Border" class="pan-fine-tune-label"/>
                                        <field name="x_pan_border_strong_color" placeholder="rgba(0, 0, 0, 0.15)"/>
                                        <field name="x_pan_dark_border_strong_color" placeholder="rgba(255, 255, 255, 0.18)"/>
                                    </div>
                                    <div class="pan-fine-tune-item">
                                        <label for="x_pan_navbar_border_color" string="Navbar Border" class="pan-fine-tune-label"/>
                                        <field name="x_pan_navbar_border_color" placeholder="rgba(0, 0, 0, 0.08)"/>
                                        <field name="x_pan_dark_navbar_border_color" placeholder="rgba(255, 255, 255, 0.09)"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <h2>Reset</h2>
                    <div class="row mt-4 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <button name="action_pan_reset_colors"
                                        type="object"
                                        string="Reset to Defaults"
                                        class="btn btn-secondary btn-sm"
                                        icon="fa-repeat"
                                        confirm="Reset all colors (light + dark) to Pantalytics defaults?"/>
                            </div>
                        </div>
                    </div>
                    <h2>About</h2>
                    <div class="row mt-4 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <div class="row">
                                    <div class="col-auto">
                                        <span class="o_form_label">Version</span>
                                        <div class="mt-1">19.0.1.2.0</div>
                                    </div>
                                    <div class="col-auto">
                                        <span class="o_form_label">Documentation</span>
                                        <div class="mt-1">
                                            <a href="https://github.com/pantalytics/odoo-style-pro" target="_blank">
                                                <i class="fa fa-external-link me-1" title="Documentation"/>github.com/pantalytics/odoo-style-pro
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-3 text-muted small">
                                    &#169; Pantalytics B.V. All rights reserved. This software is proprietary and confidential.
                                    Unauthorized copying, modification, distribution, or use of this module, in whole or in part,
                                    is strictly prohibited and may result in legal action. Protected under international copyright
                                    and trade secret law.
                                </div>
                            </div>
                        </div>
                    </div>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
