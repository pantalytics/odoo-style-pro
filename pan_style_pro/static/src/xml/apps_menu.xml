<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Replace apps dropdown content to add app icons -->
    <t t-name="pan_style_pro.AppsMenu" t-inherit="web.NavBar.AppsMenu" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='content']" position="replace">
            <t t-set-slot="content">
                <DropdownItem
                    t-foreach="apps"
                    t-as="app"
                    t-key="app.id"
                    class="{ 'o_app': true, focus: menuService.getCurrentApp() === app }"
                    onSelected="() => this.onNavBarDropdownItemSelection(app)"
                    attrs="{ href: getMenuItemHref(app), 'data-menu-xmlid': app.xmlid, 'data-section': app.id }"
                >
                    <div class="d-flex align-items-center gap-2">
                        <img t-if="app.webIconData" t-att-src="app.webIconData" class="pan-app-icon" alt=""/>
                        <span t-esc="app.name"/>
                    </div>
                </DropdownItem>
            </t>
        </xpath>
    </t>

</templates>
